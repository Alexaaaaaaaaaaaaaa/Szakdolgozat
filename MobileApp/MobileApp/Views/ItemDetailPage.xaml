<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://xamarin.com/schemas/2014/forms"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MobileApp.Views.ItemDetailPage"
             Title="{Binding Title}">

    <StackLayout Spacing="0" Padding="15">
        <Label Text="Élelmiszer neve" FontSize="Medium" FontAttributes="Bold"/>
        <Label Text="{Binding Text}" FontSize="18"/>
        <Label Text="Mennyiség" FontSize="Medium" Margin="0,10,0,0" FontAttributes="Bold"/>
        <Label Text="{Binding Description}" FontSize="18"/>
        <Label Text="Lejárati idő" FontSize="Medium" Margin="0,10,0,0" FontAttributes="Bold"/>
        <Label Text="{Binding ExpiryDate}" FontSize="18"/>
    </StackLayout>
    
</ContentPage>