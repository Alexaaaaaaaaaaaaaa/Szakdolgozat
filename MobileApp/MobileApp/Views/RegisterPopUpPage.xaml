<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://xamarin.com/schemas/2014/forms"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MobileApp.Views.RegisterPopUpPage"
             Title="Regisztráció">
    <ContentPage.Content>
        <StackLayout>
            <Image Source="{Binding ProfilePicture}" HeightRequest="150" BackgroundColor="Red" Margin="130,0,130,0"/>
            <StackLayout Orientation="Horizontal" Margin="50,0">
                <Button Text="←" FontSize="20" FontAttributes="Bold" Command="{Binding LeftPictureCommand}" HorizontalOptions="Start"/>
                <Button Text="→" FontSize="20" FontAttributes="Bold" Command="{Binding RightPictureCommand}" HorizontalOptions="EndAndExpand"/>
            </StackLayout>
            <Entry Text="{Binding Email}" Placeholder="E-mail cím" HorizontalTextAlignment="Center"/>
            <Entry Text="{Binding UserName}" Placeholder="Felhasználónév" HorizontalTextAlignment="Center"/>
            <Entry Text="{Binding Password}" Placeholder="Jelszó" IsPassword="True" HorizontalTextAlignment="Center"/>
            <Button Text="Regisztrálok!" Command="{Binding RegisterCommand}"/>
        </StackLayout>
    </ContentPage.Content>
</ContentPage>