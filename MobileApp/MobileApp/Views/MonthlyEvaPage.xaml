<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://xamarin.com/schemas/2014/forms"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MobileApp.Views.MonthlyEvaPage"
             xmlns:local="clr-namespace:MobileApp.ViewModels"
             Title="{Binding Title}"
             Shell.BackgroundColor="{Binding ShellColor}">
    <RefreshView x:DataType="local:MonthlyEvaViewModel" Command="{Binding LoadCommand}" IsRefreshing="{Binding IsBusy, Mode=TwoWay}">
        <StackLayout>
            <Image BackgroundColor="PeachPuff" HeightRequest="300" Margin="20"/>
            <Label Text="{Binding MainText}" FontSize="Large" FontAttributes="Bold" HorizontalTextAlignment="Center"/>
            <Label/>
            <Label/>
            <Grid Margin="20,20,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="18"/>
                    <ColumnDefinition Width="auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="18"/>
                </Grid.RowDefinitions>
                <Rectangle BackgroundColor="LightGray" Grid.Column="0" Grid.Row="0"/>
                <Label Text="Megvásárolt:" Grid.Column="1" Grid.Row="0" FontAttributes="Bold"/>
                <Label Text="{Binding Bought}" FontAttributes="Bold" Grid.Column="2" Grid.Row="0"/>
            </Grid>
            <Grid Margin="20,0,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="18"/>
                    <ColumnDefinition Width="auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="18"/>
                </Grid.RowDefinitions>
                <Rectangle BackgroundColor="MediumAquamarine" Grid.Column="0" Grid.Row="0"/>
                <Label Text="Felhasznált:" Grid.Column="1" Grid.Row="0" FontAttributes="Bold"/>
                <Label Text="{Binding Used}" FontAttributes="Bold" Grid.Column="2" Grid.Row="0"/>
            </Grid>
            <Grid Margin="20,0,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="18"/>
                    <ColumnDefinition Width="auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="18"/>
                </Grid.RowDefinitions>
                <Rectangle BackgroundColor="LightCoral" Grid.Column="0" Grid.Row="0"/>
                <Label Text="Kidobott:" Grid.Column="1" Grid.Row="0" FontAttributes="Bold"/>
                <Label Text="{Binding Wasted}" FontAttributes="Bold" Grid.Column="2" Grid.Row="0"/>
            </Grid>
            <Label/>
            <Grid Margin="20" ColumnSpacing="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="{Binding UsedWidth}"/>
                    <ColumnDefinition Width="{Binding WastedWidth}"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="25"/>
                </Grid.RowDefinitions>
                <Rectangle BackgroundColor="MediumAquamarine" Grid.Column="0"/>
                <Rectangle BackgroundColor="LightCoral" Grid.Column="1"/>
                <Rectangle BackgroundColor="LightGray" Grid.Column="2"/>
            </Grid>
        </StackLayout>
    </RefreshView>
</ContentPage>