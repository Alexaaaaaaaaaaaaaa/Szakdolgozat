<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://xamarin.com/schemas/2014/forms"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MobileApp.Views.ChangePassword"
             Title="{Binding Title}">
    <ContentPage.Content>
        <StackLayout>
            <Grid Grid.Row="9">
                <Entry Placeholder="Jelenlegi jelszó" IsPassword="True" Text="{Binding CurrentPassword}" HorizontalTextAlignment="Center" Margin="40,0" Grid.Row="4"/>
                <Entry Placeholder="Új jelszó" IsPassword="True" Text="{Binding NewPassword1}" HorizontalTextAlignment="Center" Margin="30,0" Grid.Row="5"/>
                <Entry Placeholder="Új jelszó újra" IsPassword="True" Text="{Binding NewPassword2}" HorizontalTextAlignment="Center" Margin="20,0" Grid.Row="6"/>
                <Label Text="{Binding ErrorMessage}" TextColor="Red" FontAttributes="Bold" Grid.Row="7" HorizontalTextAlignment="Center"/>
            </Grid>
            <Button Text="Jelszó megváltoztatása" Command="{Binding ChangePassword}" Margin="40" VerticalOptions="EndAndExpand"/>
        </StackLayout>
    </ContentPage.Content>
</ContentPage>